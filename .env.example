# =============================================================================
# DreamBig / GamePulse AI — environment variables
# Copy to `.env` and fill in the blanks before running `docker-compose up -d`.
# =============================================================================

# --- Database / cache (docker-compose defaults; override for external DB) ---
DATABASE_URL=postgresql://dreambig:dreambig@db:5432/dreambig
REDIS_URL=redis://redis:6379/0

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Poe API (required for LLM: sentiment / topics / report generation) ---
# Get one at https://poe.com/api_key
POE_API_KEY=your_poe_api_key_here

# --- Scraper settings ---
# Residential/rotating proxy for Google Play / App Store non-home regions.
# Format: http://user:pass@host:port
SCRAPE_PROXY_URL=
SCRAPE_CONCURRENCY=3

# --- Third-party data providers ---
# TikHub API (douyin / tiktok social signals) — https://tikhub.io/
TIKHUB_API_KEY=
# TikHub cost controls. Each social-depth game costs 2 TikHub calls (Douyin +
# TikTok). Budget formula: monthly_calls = 30 days × SOCIAL_DEPTH_GAME_LIMIT × 2
#   plan 600/mo   → SOCIAL_DEPTH_GAME_LIMIT=8   (480/mo, 20% headroom)
#   plan 10k/mo   → SOCIAL_DEPTH_GAME_LIMIT=100 + SOCIAL_SIGNALS_USE_TIKHUB=true
#   plan 100k/mo  → set both high, you're unbounded
SOCIAL_DEPTH_GAME_LIMIT=8
# If your TikHub plan is tight, leave this "false" — the aggregate-level
# social_signals job (runs daily over top-50 games) will then skip
# Douyin/TikTok entirely and only hit the free Bilibili API. Set to "true"
# only if you have headroom (≥ 3500 TikHub calls/month for the 50-game sweep).
SOCIAL_SIGNALS_USE_TIKHUB=false
# AppGrowing (paid ad intelligence) — https://appgrowing.cn/
APPGROWING_API_KEY=
# Steam Web API — NOTE: the codebase defines this but never reads it. The
# Steam scraper uses public endpoints (Store API + SteamSpy) that don't
# need authentication. Safe to leave blank.
STEAM_API_KEY=

# --- Notifications ---
# Feishu (Lark) custom bot webhook for P1/P2 alert pushes.
# See https://open.feishu.cn/document/client-docs/bot-v3/add-custom-bot
FEISHU_WEBHOOK_URL=

# ============================================================
# Phase 2 — Authentication (NextAuth v5)
# ============================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_min_32_chars
# Set to the exact URL users access the site through.
#   - Local dev:   http://localhost:3000
#   - IP-only VPS: http://1.2.3.4           (port 80 via Caddy, no trailing slash)
#   - Domain+SSL:  https://dreambig.example.com
# NOTE: trustHost is already hard-coded in lib/auth.ts so AUTH_TRUST_HOST env
# var is NOT needed. This URL is still used by NextAuth for callback construction.
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# Phase 2 — OpenAI Embeddings (for similar games)
# Poe API does not provide embeddings; we use OpenAI directly
# ============================================================
OPENAI_API_KEY=sk-your_openai_api_key

# ============================================================
# Phase 2 — YouTube Data API (for social depth)
# Get from https://console.cloud.google.com/
# ============================================================
YOUTUBE_API_KEY=your_youtube_data_api_key

# ============================================================
# Phase 2 — SMTP (for email digest notifications)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com

# ============================================================
# Phase 3/4 — Feishu Bot (optional, for /analyze /iaa /similar /trending commands)
# ============================================================
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFICATION_TOKEN=your_verification_token
