generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Core game entity (deduplicated across platforms)
// ============================================================
model Game {
  id             Int       @id @default(autoincrement())
  nameZh         String?   @map("name_zh")
  nameEn         String?   @map("name_en")
  developer      String?
  genre          String?
  subGenres      String[]  @map("sub_genres")
  gameplayTags   String[]  @map("gameplay_tags")
  iaaSuitability Int       @default(0) @map("iaa_suitability")
  metadata       Json      @default("{}")
  thumbnailUrl   String?   @map("thumbnail_url")
  positioning    String?
  coreLoop       String?   @map("core_loop")
  metaLoop       String?   @map("meta_loop")
  pleasurePoints String[]  @default([]) @map("pleasure_points")
  replayDrivers  String[]  @default([]) @map("replay_drivers")
  iaaGrade       String?   @map("iaa_grade")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  platformListings    PlatformListing[]
  socialSignals       SocialSignal[]
  adIntelligence      AdIntelligence[]
  potentialScores     PotentialScore[]
  alertEvents         AlertEvent[]
  gameTags            GameTag[]
  reviewTopicSummaries ReviewTopicSummary[]
  gameReport          GameReport?
  gameEmbedding       GameEmbedding?

  @@map("games")
}

// ============================================================
// Platform-specific listing (one per game per platform)
// ============================================================
model PlatformListing {
  id          Int       @id @default(autoincrement())
  gameId      Int       @map("game_id")
  platform    String    // google_play, app_store, taptap, steam, etc.
  platformId  String    @map("platform_id")
  platformUrl String?   @map("platform_url")
  name        String
  rating      Decimal?  @db.Decimal(3, 2)
  ratingCount Int?      @map("rating_count")
  downloadEst BigInt?   @map("download_est")
  releaseDate DateTime? @map("release_date") @db.Date
  lastUpdated DateTime? @default(now()) @map("last_updated") @db.Date
  metadata    Json      @default("{}")

  game              Game               @relation(fields: [gameId], references: [id])
  rankingSnapshots  RankingSnapshot[]
  reviews           Review[]

  @@unique([platform, platformId])
  @@map("platform_listings")
}

// ============================================================
// Ranking snapshots (time-series, fastest growing table)
// ============================================================
model RankingSnapshot {
  id                Int      @id @default(autoincrement())
  platformListingId Int      @map("platform_listing_id")
  chartType         String   @map("chart_type") // top_free, top_grossing, trending, new
  region            String   @default("CN")
  rankPosition      Int      @map("rank_position") @db.SmallInt
  previousRank      Int?     @map("previous_rank") @db.SmallInt
  rankChange        Int?     @map("rank_change") @db.SmallInt
  snapshotDate      DateTime @map("snapshot_date") @db.Date

  platformListing PlatformListing @relation(fields: [platformListingId], references: [id])

  @@unique([platformListingId, chartType, region, snapshotDate])
  @@index([snapshotDate(sort: Desc)])
  @@index([platformListingId, snapshotDate(sort: Desc)])
  @@map("ranking_snapshots")
}

// ============================================================
// Social media signals
// ============================================================
model SocialSignal {
  id            Int      @id @default(autoincrement())
  gameId        Int      @map("game_id")
  platform      String   // douyin, bilibili, tiktok, youtube
  videoCount    Int      @default(0) @map("video_count")
  viewCount     BigInt   @default(0) @map("view_count")
  likeCount     BigInt   @default(0) @map("like_count")
  hashtagVolume Int      @default(0) @map("hashtag_volume")
  signalDate    DateTime @map("signal_date") @db.Date
  metadata      Json     @default("{}")

  game Game @relation(fields: [gameId], references: [id])

  @@unique([gameId, platform, signalDate])
  @@map("social_signals")
}

// ============================================================
// Ad intelligence
// ============================================================
model AdIntelligence {
  id              Int       @id @default(autoincrement())
  gameId          Int       @map("game_id")
  source          String    // facebook_ad_library, appgrowing
  activeCreatives Int       @default(0) @map("active_creatives")
  markets         String[]
  creativeTypes   String[]  @map("creative_types")
  estimatedSpend  String?   @map("estimated_spend")
  firstSeen       DateTime? @map("first_seen") @db.Date
  lastSeen        DateTime? @map("last_seen") @db.Date
  signalDate      DateTime  @map("signal_date") @db.Date
  metadata        Json      @default("{}")

  game Game @relation(fields: [gameId], references: [id])

  @@unique([gameId, source, signalDate])
  @@map("ad_intelligence")
}

// ============================================================
// Potential scores (computed daily)
// ============================================================
model PotentialScore {
  id               Int      @id @default(autoincrement())
  gameId           Int      @map("game_id")
  overallScore     Int      @map("overall_score") @db.SmallInt
  rankingVelocity  Int      @default(0) @map("ranking_velocity") @db.SmallInt
  genreFit         Int      @default(0) @map("genre_fit") @db.SmallInt
  socialBuzz       Int      @default(0) @map("social_buzz") @db.SmallInt
  crossPlatform    Int      @default(0) @map("cross_platform") @db.SmallInt
  ratingQuality    Int      @default(0) @map("rating_quality") @db.SmallInt
  competitionGap   Int      @default(0) @map("competition_gap") @db.SmallInt
  adActivity       Int      @default(0) @map("ad_activity") @db.SmallInt
  algorithmVersion String   @default("v1") @map("algorithm_version")
  scoredAt         DateTime @map("scored_at") @db.Date

  game Game @relation(fields: [gameId], references: [id])

  @@unique([gameId, scoredAt])
  @@map("potential_scores")
}

// ============================================================
// Alert rules
// ============================================================
model Alert {
  id            Int      @id @default(autoincrement())
  name          String
  alertType     String   @map("alert_type") // ranking_jump, review_burst, social_burst, steam_momentum, taptap_heat
  severity      String   @default("P2") // P1, P2, P3
  conditions    Json     // {"min_score": 70, "genres": ["puzzle","idle"]}
  notifyChannel String   @default("feishu") @map("notify_channel")
  webhookUrl    String?  @map("webhook_url")
  isActive      Boolean  @default(true) @map("is_active")
  cooldownHours Int      @default(24) @map("cooldown_hours")
  createdAt     DateTime @default(now()) @map("created_at")

  alertEvents AlertEvent[]

  @@map("alerts")
}

// ============================================================
// Alert events (triggered alerts history)
// ============================================================
model AlertEvent {
  id           Int      @id @default(autoincrement())
  alertId      Int      @map("alert_id")
  gameId       Int      @map("game_id")
  score        Int?     @db.SmallInt
  alertType    String?  @map("alert_type")
  severity     String?
  reason       String?
  triggeredAt  DateTime @default(now()) @map("triggered_at")
  acknowledged Boolean  @default(false)

  alert Alert @relation(fields: [alertId], references: [id])
  game  Game  @relation(fields: [gameId], references: [id])

  @@map("alert_events")
}

// ============================================================
// Game tags (manual curation)
// ============================================================
model GameTag {
  gameId  Int      @map("game_id")
  tag     String   // watchlist, contacted, licensed, rejected, porting
  note    String?
  taggedAt DateTime @default(now()) @map("tagged_at")

  game Game @relation(fields: [gameId], references: [id])

  @@id([gameId, tag])
  @@map("game_tags")
}

// ============================================================
// Scrape job tracking
// ============================================================
model ScrapeJob {
  id           Int       @id @default(autoincrement())
  platform     String
  jobType      String    @map("job_type") // rankings, details, social, ads
  status       String    @default("pending") // pending, running, success, failed
  itemsScraped Int       @default(0) @map("items_scraped")
  errorMessage String?   @map("error_message")
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  retryCount   Int       @default(0) @map("retry_count")

  @@map("scrape_jobs")
}

// ============================================================
// Reviews (scraped review content per platform listing)
// ============================================================
model Review {
  id                  Int       @id @default(autoincrement())
  platformListingId   Int       @map("platform_listing_id")
  externalId          String    @map("external_id")
  rating              Int?      @db.SmallInt
  content             String    @db.Text
  authorName          String?   @map("author_name")
  helpfulCount        Int?      @map("helpful_count")
  language            String?
  postedAt            DateTime  @map("posted_at")
  sentiment           String?
  topics              String[]  @default([])
  sentimentConfidence Decimal?  @map("sentiment_confidence") @db.Decimal(3, 2)
  scrapedAt           DateTime  @default(now()) @map("scraped_at")

  platformListing PlatformListing @relation(fields: [platformListingId], references: [id])

  @@unique([platformListingId, externalId])
  @@index([platformListingId, postedAt(sort: Desc)])
  @@index([postedAt(sort: Desc)])
  @@map("reviews")
}

// ============================================================
// Review topic summaries (LLM-clustered topics per game)
// ============================================================
model ReviewTopicSummary {
  id              Int      @id @default(autoincrement())
  gameId          Int      @map("game_id")
  topic           String
  sentiment       String   // positive, negative
  sampleReviewIds Int[]    @default([]) @map("sample_review_ids")
  snippet         String
  reviewCount     Int      @map("review_count")
  computedAt      DateTime @map("computed_at") @db.Date

  game Game @relation(fields: [gameId], references: [id])

  @@unique([gameId, topic, sentiment, computedAt])
  @@map("review_topic_summaries")
}

// ============================================================
// Game reports (LLM-generated full report, one per game)
// ============================================================
model GameReport {
  id            Int      @id @default(autoincrement())
  gameId        Int      @unique @map("game_id")
  payload       Json
  promptVersion String   @map("prompt_version")
  modelUsed     String   @map("model_used")
  evidenceCount Int      @map("evidence_count")
  confidence    Decimal  @db.Decimal(3, 2)
  tokensUsed    Int?     @map("tokens_used")
  costUsd       Decimal? @map("cost_usd") @db.Decimal(10, 4)
  generatedAt   DateTime @map("generated_at")

  game Game @relation(fields: [gameId], references: [id])

  @@map("game_reports")
}

// ============================================================
// Game embeddings (vector embeddings for similarity search)
// ============================================================
model GameEmbedding {
  gameId     Int                          @id @map("game_id")
  embedding  Unsupported("vector(1536)")
  source     String
  dim        Int                          @default(1536)
  computedAt DateTime                     @map("computed_at")

  game Game @relation(fields: [gameId], references: [id])

  @@map("game_embeddings")
}
