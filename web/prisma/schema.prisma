generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Core game entity (deduplicated across platforms)
// ============================================================
model Game {
  id             Int      @id @default(autoincrement())
  nameZh         String?  @map("name_zh")
  nameEn         String?  @map("name_en")
  developer      String?
  genre          String?
  subGenres      String[] @map("sub_genres")
  gameplayTags   String[] @map("gameplay_tags")
  iaaSuitability Int      @default(0) @map("iaa_suitability")
  metadata       Json     @default("{}")
  thumbnailUrl   String?  @map("thumbnail_url")
  positioning    String?
  coreLoop       String?  @map("core_loop")
  metaLoop       String?  @map("meta_loop")
  pleasurePoints String[] @default([]) @map("pleasure_points")
  replayDrivers  String[] @default([]) @map("replay_drivers")
  iaaGrade       String?  @map("iaa_grade")
  // ---- 80/20 组合创新拆解 (Sprint 1 deep fix) ----
  inheritedMechanics String[] @default([]) @map("inherited_mechanics")
  innovationPoints   String[] @default([]) @map("innovation_points")
  maturityRatio      Decimal? @db.Decimal(3, 2) @map("maturity_ratio")
  innovationRatio    Decimal? @db.Decimal(3, 2) @map("innovation_ratio")
  combinationPattern String?  @map("combination_pattern")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  platformListings     PlatformListing[]
  socialSignals        SocialSignal[]
  adIntelligence       AdIntelligence[]
  potentialScores      PotentialScore[]
  alertEvents          AlertEvent[]
  gameTags             GameTag[]
  reviewTopicSummaries ReviewTopicSummary[]
  gameReport           GameReport?
  gameEmbedding        GameEmbedding?
  socialContentSamples SocialContentSample[]
  experiments          Experiment[]
  assetAnalyses        GameAssetAnalysis[]
  webSources           GameWebSource[]

  @@map("games")
}

// ============================================================
// Platform-specific listing (one per game per platform)
// ============================================================
model PlatformListing {
  id          Int       @id @default(autoincrement())
  gameId      Int       @map("game_id")
  platform    String // google_play, app_store, taptap, steam, etc.
  platformId  String    @map("platform_id")
  platformUrl String?   @map("platform_url")
  name        String
  rating      Decimal?  @db.Decimal(3, 2)
  ratingCount Int?      @map("rating_count")
  downloadEst BigInt?   @map("download_est")
  releaseDate DateTime? @map("release_date") @db.Date
  lastUpdated DateTime? @default(now()) @map("last_updated") @db.Date
  metadata    Json      @default("{}")

  game             Game              @relation(fields: [gameId], references: [id])
  rankingSnapshots RankingSnapshot[]
  reviews          Review[]

  @@unique([platform, platformId])
  @@map("platform_listings")
}

// ============================================================
// Ranking snapshots (time-series, fastest growing table)
// ============================================================
model RankingSnapshot {
  id                Int      @id @default(autoincrement())
  platformListingId Int      @map("platform_listing_id")
  chartType         String   @map("chart_type") // top_free, top_grossing, trending, new
  region            String   @default("CN")
  rankPosition      Int      @map("rank_position") @db.SmallInt
  previousRank      Int?     @map("previous_rank") @db.SmallInt
  rankChange        Int?     @map("rank_change") @db.SmallInt
  snapshotDate      DateTime @map("snapshot_date") @db.Date

  platformListing PlatformListing @relation(fields: [platformListingId], references: [id])

  @@unique([platformListingId, chartType, region, snapshotDate])
  @@index([snapshotDate(sort: Desc)])
  @@index([platformListingId, snapshotDate(sort: Desc)])
  @@map("ranking_snapshots")
}

// ============================================================
// Social media signals
// ============================================================
model SocialSignal {
  id            Int      @id @default(autoincrement())
  gameId        Int      @map("game_id")
  platform      String // douyin, bilibili, tiktok, youtube
  videoCount    Int      @default(0) @map("video_count")
  viewCount     BigInt   @default(0) @map("view_count")
  likeCount     BigInt   @default(0) @map("like_count")
  hashtagVolume Int      @default(0) @map("hashtag_volume")
  signalDate    DateTime @map("signal_date") @db.Date
  metadata      Json     @default("{}")

  game Game @relation(fields: [gameId], references: [id])

  @@unique([gameId, platform, signalDate])
  @@map("social_signals")
}

// ============================================================
// Ad intelligence
// ============================================================
model AdIntelligence {
  id              Int       @id @default(autoincrement())
  gameId          Int       @map("game_id")
  source          String // facebook_ad_library, appgrowing
  activeCreatives Int       @default(0) @map("active_creatives")
  markets         String[]
  creativeTypes   String[]  @map("creative_types")
  estimatedSpend  String?   @map("estimated_spend")
  firstSeen       DateTime? @map("first_seen") @db.Date
  lastSeen        DateTime? @map("last_seen") @db.Date
  signalDate      DateTime  @map("signal_date") @db.Date
  metadata        Json      @default("{}")

  game Game @relation(fields: [gameId], references: [id])

  @@unique([gameId, source, signalDate])
  @@map("ad_intelligence")
}

// ============================================================
// Potential scores (computed daily)
// ============================================================
model PotentialScore {
  id               Int      @id @default(autoincrement())
  gameId           Int      @map("game_id")
  overallScore     Int      @map("overall_score") @db.SmallInt
  rankingVelocity  Int      @default(0) @map("ranking_velocity") @db.SmallInt
  genreFit         Int      @default(0) @map("genre_fit") @db.SmallInt
  socialBuzz       Int      @default(0) @map("social_buzz") @db.SmallInt
  crossPlatform    Int      @default(0) @map("cross_platform") @db.SmallInt
  ratingQuality    Int      @default(0) @map("rating_quality") @db.SmallInt
  competitionGap   Int      @default(0) @map("competition_gap") @db.SmallInt
  adActivity       Int      @default(0) @map("ad_activity") @db.SmallInt
  // ---- Sprint 1 deep fix: breakout + iaa 双轨 (shadow mode) ----
  breakoutScore     Int?     @map("breakout_score") @db.SmallInt
  mechanicMaturity  Int      @default(0) @map("mechanic_maturity") @db.SmallInt
  combinationHealth Int      @default(0) @map("combination_health") @db.SmallInt
  marketValidation  Int      @default(0) @map("market_validation") @db.SmallInt
  iaaScore          Int?     @map("iaa_score") @db.SmallInt
  placementFit      Int      @default(0) @map("placement_fit") @db.SmallInt
  monetizationRisk  Int      @default(0) @map("monetization_risk") @db.SmallInt
  adOpportunities   Int      @default(0) @map("ad_opportunities") @db.SmallInt
  genreIaaFit       Int      @default(0) @map("genre_iaa_fit") @db.SmallInt
  algorithmVersion String   @default("v1") @map("algorithm_version")
  scoredAt         DateTime @map("scored_at") @db.Date

  game Game @relation(fields: [gameId], references: [id])

  @@unique([gameId, scoredAt])
  @@map("potential_scores")
}

// ============================================================
// Alert rules
// ============================================================
model Alert {
  id            Int      @id @default(autoincrement())
  workspaceId   String   @map("workspace_id")
  name          String
  alertType     String   @map("alert_type") // ranking_jump, review_burst, social_burst, steam_momentum, taptap_heat
  severity      String   @default("P2") // P1, P2, P3
  conditions    Json // {"min_score": 70, "genres": ["puzzle","idle"]}
  notifyChannel String   @default("feishu") @map("notify_channel")
  webhookUrl    String?  @map("webhook_url")
  isActive      Boolean  @default(true) @map("is_active")
  cooldownHours Int      @default(24) @map("cooldown_hours")
  createdAt     DateTime @default(now()) @map("created_at")

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  alertEvents AlertEvent[]

  @@index([workspaceId])
  @@map("alerts")
}

// ============================================================
// Alert events (triggered alerts history)
// ============================================================
model AlertEvent {
  id           Int      @id @default(autoincrement())
  alertId      Int      @map("alert_id")
  gameId       Int      @map("game_id")
  score        Int?     @db.SmallInt
  alertType    String?  @map("alert_type")
  severity     String?
  reason       String?
  triggeredAt  DateTime @default(now()) @map("triggered_at")
  acknowledged Boolean  @default(false)

  alert Alert @relation(fields: [alertId], references: [id])
  game  Game  @relation(fields: [gameId], references: [id])

  @@map("alert_events")
}

// ============================================================
// Game tags (manual curation)
// ============================================================
model GameTag {
  gameId      Int      @map("game_id")
  tag         String // watchlist, contacted, licensed, rejected, porting
  workspaceId String   @map("workspace_id")
  note        String?
  taggedAt    DateTime @default(now()) @map("tagged_at")

  game      Game      @relation(fields: [gameId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([gameId, tag, workspaceId])
  @@index([workspaceId])
  @@map("game_tags")
}

// ============================================================
// Scrape job tracking
// ============================================================
model ScrapeJob {
  id           Int       @id @default(autoincrement())
  platform     String
  jobType      String    @map("job_type") // rankings, details, social, ads
  status       String    @default("pending") // pending, running, success, failed
  itemsScraped Int       @default(0) @map("items_scraped")
  errorMessage String?   @map("error_message")
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  retryCount   Int       @default(0) @map("retry_count")

  @@map("scrape_jobs")
}

// ============================================================
// Reviews (scraped review content per platform listing)
// ============================================================
model Review {
  id                  Int      @id @default(autoincrement())
  platformListingId   Int      @map("platform_listing_id")
  externalId          String   @map("external_id")
  rating              Int?     @db.SmallInt
  content             String   @db.Text
  authorName          String?  @map("author_name")
  helpfulCount        Int?     @map("helpful_count")
  language            String?
  postedAt            DateTime @map("posted_at")
  sentiment           String?
  topics              String[] @default([])
  sentimentConfidence Decimal? @map("sentiment_confidence") @db.Decimal(3, 2)
  scrapedAt           DateTime @default(now()) @map("scraped_at")

  platformListing PlatformListing @relation(fields: [platformListingId], references: [id])

  @@unique([platformListingId, externalId])
  @@index([platformListingId, postedAt(sort: Desc)])
  @@index([postedAt(sort: Desc)])
  @@map("reviews")
}

// ============================================================
// Review topic summaries (LLM-clustered topics per game)
// ============================================================
model ReviewTopicSummary {
  id              Int      @id @default(autoincrement())
  gameId          Int      @map("game_id")
  topic           String
  sentiment       String // positive, negative
  sampleReviewIds Int[]    @default([]) @map("sample_review_ids")
  snippet         String
  reviewCount     Int      @map("review_count")
  computedAt      DateTime @map("computed_at") @db.Date

  game Game @relation(fields: [gameId], references: [id])

  @@unique([gameId, topic, sentiment, computedAt])
  @@map("review_topic_summaries")
}

// ============================================================
// Game reports (LLM-generated full report, one per game)
// ============================================================
model GameReport {
  id            Int      @id @default(autoincrement())
  gameId        Int      @unique @map("game_id")
  payload       Json
  promptVersion String   @map("prompt_version")
  modelUsed     String   @map("model_used")
  evidenceCount Int      @map("evidence_count")
  confidence    Decimal  @db.Decimal(3, 2)
  tokensUsed    Int?     @map("tokens_used")
  costUsd       Decimal? @map("cost_usd") @db.Decimal(10, 4)
  generatedAt   DateTime @map("generated_at")

  game Game @relation(fields: [gameId], references: [id])

  @@map("game_reports")
}

// ============================================================
// Game embeddings (vector embeddings for similarity search)
// ============================================================
model GameEmbedding {
  gameId     Int                         @id @map("game_id")
  embedding  Unsupported("vector(1536)")
  source     String
  dim        Int                         @default(1536)
  computedAt DateTime                    @map("computed_at")

  game Game @relation(fields: [gameId], references: [id])

  @@map("game_embeddings")
}

// ============================================================
// Phase 2: Auth (NextAuth.js v5 compatible)
// ============================================================
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime? @map("email_verified")
  name            String?
  image           String?
  passwordHash    String?   @map("password_hash") // for credentials provider
  role            String    @default("viewer") // super_admin/analyst/publisher/monetization/viewer
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  lastLoginAt     DateTime? @map("last_login_at")
  lastWorkspaceId String?   @map("last_workspace_id")

  accounts         Account[]
  sessions         Session[]
  subscriptions    Subscription[]
  auditLogs        AuditLog[]
  workspaceMembers WorkspaceMember[]
  lastWorkspace    Workspace?        @relation("UserLastWorkspace", fields: [lastWorkspaceId], references: [id], onDelete: SetNull)

  @@map("users")
}

// ============================================================
// Phase 3-4: Workspace (multi-tenant business actions)
// ============================================================
// Per-tenant tables: alerts, subscriptions, experiments, game_tags, audit_logs.
// Game data (games / platform_listings / reviews / reports) stays globally shared.
model Workspace {
  id          String   @id
  name        String
  slug        String   @unique
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  members       WorkspaceMember[]
  alerts        Alert[]
  subscriptions Subscription[]
  experiments   Experiment[]
  gameTags      GameTag[]
  auditLogs     AuditLog[]
  pinnedByUsers User[]            @relation("UserLastWorkspace")

  @@index([isDefault])
  @@map("workspaces")
}

model WorkspaceMember {
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("analyst") // super_admin/analyst/publisher/monetization/viewer
  joinedAt    DateTime @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

// ============================================================
// Phase 2: Account (OAuth providers, NextAuth standard)
// ============================================================
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ============================================================
// Phase 2: Session (NextAuth standard)
// ============================================================
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================================
// Phase 2: VerificationToken (NextAuth standard)
// ============================================================
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// Phase 2: Audit log (user actions trail)
// ============================================================
model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      String?  @map("user_id")
  workspaceId String?  @map("workspace_id")
  action      String // "create_alert"/"update_threshold"/"export_report"/"tag_game"/...
  resource    String // "alert:123"/"game:45"/...
  diff        Json? // before/after for sensitive changes
  ip          String?
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([resource])
  @@map("audit_logs")
}

// ============================================================
// Phase 2: Subscription (订阅中心 - user-driven notification rules)
// ============================================================
model Subscription {
  id            Int       @id @default(autoincrement())
  userId        String    @map("user_id")
  workspaceId   String    @map("workspace_id")
  dimension     String // "platform"/"genre"/"region"/"keyword"/"game"
  value         String // e.g. "app_store", "idle", "US", "roguelike", "123" (game id)
  channel       String // "feishu"/"wecom"/"email"
  channelConfig Json      @default("{}") @map("channel_config") // {"webhook_url": "..."} or {"email": "..."}
  schedule      String? // null = realtime, "daily"/"weekly", or cron expression
  isActive      Boolean   @default(true) @map("is_active")
  lastSentAt    DateTime? @map("last_sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([dimension, value])
  @@map("subscriptions")
}

// ============================================================
// Phase 2: Genre (aggregation/rollup table — refreshed daily)
// ============================================================
model Genre {
  key            String    @id // e.g. "idle", "merge"
  labelZh        String    @map("label_zh")
  labelEn        String    @map("label_en")
  iaaBaseline    Int       @default(0) @map("iaa_baseline")
  hotGamesCount  Int       @default(0) @map("hot_games_count") // games with overall_score >= 60
  momentum       Decimal   @default(0) @db.Decimal(6, 3) // 7d avg delta
  topGameIds     Int[]     @default([]) @map("top_game_ids")
  lastComputedAt DateTime? @map("last_computed_at")

  @@map("genres")
}

// ============================================================
// Phase 2: Social content samples (video titles + hook phrases)
// ============================================================
model SocialContentSample {
  id           Int      @id @default(autoincrement())
  gameId       Int      @map("game_id")
  platform     String // "douyin"/"tiktok"/"youtube"/"bilibili"
  contentType  String   @map("content_type") // "video"/"post"
  externalId   String   @map("external_id")
  title        String
  authorName   String?  @map("author_name")
  hashtags     String[] @default([])
  viewCount    BigInt   @default(0) @map("view_count")
  likeCount    BigInt?  @map("like_count")
  commentCount Int?     @map("comment_count")
  hookPhrase   String?  @map("hook_phrase") // LLM-extracted
  url          String?
  postedAt     DateTime @map("posted_at")
  scrapedAt    DateTime @default(now()) @map("scraped_at")
  metadata     Json     @default("{}")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([platform, externalId])
  @@index([gameId, postedAt(sort: Desc)])
  @@index([platform, viewCount(sort: Desc)])
  @@map("social_content_samples")
}

// ============================================================
// Phase 3-3: Experiments (A/B test tracker)
// ============================================================
model Experiment {
  id            Int       @id @default(autoincrement())
  gameId        Int       @map("game_id")
  workspaceId   String    @map("workspace_id")
  name          String
  hypothesis    String    @db.Text
  variantA      Json      @map("variant_a")
  variantB      Json      @map("variant_b")
  successMetric String    @map("success_metric")
  sampleSize    Int?      @map("sample_size")
  status        String    @default("draft")
  priority      Int       @default(3) @db.SmallInt
  expectedLift  Decimal?  @map("expected_lift") @db.Decimal(5, 2)
  actualLift    Decimal?  @map("actual_lift") @db.Decimal(5, 2)
  notes         String?   @db.Text
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  game      Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([gameId, createdAt(sort: Desc)])
  @@index([workspaceId])
  @@index([status])
  @@map("experiments")
}

// ============================================================
// Phase 4-1: Game asset analysis (visual analysis results)
// ============================================================
model GameAssetAnalysis {
  id           Int      @id @default(autoincrement())
  gameId       Int      @map("game_id")
  assetType    String   @map("asset_type")
  assetUrl     String   @map("asset_url") @db.Text
  analysisType String   @map("analysis_type")
  result       Json
  modelUsed    String   @map("model_used")
  confidence   Decimal? @db.Decimal(3, 2)
  tokensUsed   Int?     @map("tokens_used")
  costUsd      Decimal? @map("cost_usd") @db.Decimal(10, 4)
  analyzedAt   DateTime @default(now()) @map("analyzed_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId, assetType])
  @@index([analysisType, analyzedAt(sort: Desc)])
  @@map("game_asset_analysis")
}

// ============================================================
// Phase 4-3: Feishu bot command log (bot interaction log)
// ============================================================
model FeishuBotCommand {
  id         Int       @id @default(autoincrement())
  messageId  String    @unique @map("message_id")
  userOpenId String?   @map("user_open_id")
  chatId     String?   @map("chat_id")
  command    String
  args       String?
  status     String    @default("pending")
  response   String?   @db.Text
  errorMsg   String?   @map("error_msg")
  responseAt DateTime? @map("response_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([userOpenId, createdAt(sort: Desc)])
  @@map("feishu_bot_commands")
}

// ============================================================
// Phase 3-1 weekly / 3-2 batch advice storage (generated reports)
// ============================================================
model GeneratedReport {
  id            Int      @id @default(autoincrement())
  reportType    String   @map("report_type")
  scope         String
  title         String
  summary       String?  @db.Text
  payload       Json
  evidenceCount Int      @default(0) @map("evidence_count")
  modelUsed     String?  @map("model_used")
  tokensUsed    Int?     @map("tokens_used")
  costUsd       Decimal? @map("cost_usd") @db.Decimal(10, 4)
  generatedAt   DateTime @default(now()) @map("generated_at")

  @@unique([reportType, scope])
  @@index([reportType, generatedAt(sort: Desc)])
  @@map("generated_reports")
}

// ============================================================
// Phase 4+: game_web_sources — raw public-web hits scraped per
// game for the gameplay_intel multi-source pipeline. 7-day TTL cache.
// ============================================================
model GameWebSource {
  id            Int      @id @default(autoincrement())
  gameId        Int      @map("game_id")
  sourceSite    String   @map("source_site") // bing / bilibili_article / gamelook / youxiputao
  url           String
  title         String?
  snippet       String?
  contentText   String?  @map("content_text") @db.Text
  query         String?
  httpStatus    Int?     @map("http_status")
  fetchedAt     DateTime @default(now()) @map("fetched_at")
  ttlExpiresAt  DateTime @map("ttl_expires_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, sourceSite, url])
  @@index([gameId, fetchedAt(sort: Desc)])
  @@index([ttlExpiresAt])
  @@map("game_web_sources")
}

// ============================================================
// Sprint 1 deep fix — Proven mechanics reference library
// 用途：LLM prompt 的白名单候选池，防止 LLM 编造 tag；
//      也是 scoring._calc_mechanic_maturity 的查表基础。
// 初始化：shared/proven_mechanics.json → seed_proven_mechanics.py
// ============================================================
model ProvenMechanic {
  id               Int      @id @default(autoincrement())
  tag              String   @unique
  labelZh          String   @map("label_zh")
  labelEn          String   @map("label_en")
  category         String // core_loop / meta_loop / monetization / social
  maturityLevel    Int      @default(5) @map("maturity_level") @db.SmallInt
  iaaFriendliness  Int      @default(50) @map("iaa_friendliness") @db.SmallInt
  description      String   @db.Text
  referenceGameIds Int[]    @default([]) @map("reference_game_ids")
  synonyms         String[] @default([])
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([category])
  @@map("proven_mechanics")
}
